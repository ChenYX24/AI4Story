# 服务器 .env — 部署时复制成 /root/hackthron/AI4Story/.env，systemd 会读它注入到 uvicorn。
# !!! 这份文件本身不要写真实 secret，复制成 .env 之后再填。.env 已被 .gitignore 忽略。

# ---------- 存储 ----------
MINDSHOW_STORAGE=oss
MINDSHOW_OSS_BUCKET=mindshow-pku
MINDSHOW_OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
MINDSHOW_OSS_PREFIX=mindshow/
MINDSHOW_OSS_AK_ID=__FILL_ME__
MINDSHOW_OSS_AK_SECRET=__FILL_ME__
# 可选：CDN 加速域名（绑定后回写到这里）
# MINDSHOW_OSS_PUBLIC_BASE=https://cdn.your-domain.com

# ---------- 模型 / 三方 ----------
ARK_API_KEY=__FILL_ME__
DASHSCOPE_API_KEY=__FILL_ME__
XIAOMI_TTS_API_KEY=__FILL_ME__

# ---------- 账号系统 ----------
MINDSHOW_AUTH_SALT=__pick-a-random-32-char-string__

# ---------- 前端 ----------
# 给 vite build 用 — 部署脚本会读这一行决定 dist 里 baked 的 API 地址。
# 同源（nginx 反代）写空字符串 / 不写。如果前后端真的跨域就填 https://api.your-domain.com
VITE_API_BASE=
